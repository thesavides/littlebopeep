r-transparent\" value=\"\"/></div><div><label for=\"password\" class=\"block text-sm font-medium text-gray-700 mb-1\">Password<!-- --> <span class=\"text-red-500\">*</span></label><div class=\"relative\"><input id=\"password\" type=\"password\" required=\"\" autoComplete=\"current-password\" class=\"w-full px-4 py-3 pr-12 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent border-gray-300\" placeholder=\"••••••••\" value=\"\"/><button type=\"button\" class=\"absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 hover:text-gray-700 transition-colors\" title=\"Show password\"><svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\"></path><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z\"></path></svg></button></div></div><div class=\"text-right -mt-1\"><button type=\"button\" class=\"text-xs text-slate-400 hover:text-green-600 transition-colors\">Forgot password?</button></div><button type=\"submit\" class=\"w-full py-4 bg-green-600 text-white rounded-xl font-semibold hover:bg-green-700 active:scale-[0.98] transition-all disabled:opacity-50 disabled:cursor-not-allowed shadow-sm\">Sign In →</button></form></div></div><div class=\"mt-16 max-w-2xl mx-auto\"><h2 class=\"text-center text-xl font-bold text-slate-700 mb-8\">How it works</h2><div class=\"grid grid-cols-3 gap-6 text-center\"><div class=\"flex flex-col items-center gap-2\"><div class=\"w-12 h-12 rounded-full bg-green-100 flex items-center justify-center text-xl\">🚶</div><p class=\"font-semibold text-slate-800 text-sm\">Spot</p><p class=\"text-xs text-slate-500 leading-snug\">Walker sees lost sheep on their route</p></div><div class=\"flex flex-col items-center gap-2\"><div class=\"w-12 h-12 rounded-full bg-green-100 flex items-center justify-center text-xl\">📍</div><p class=\"font-semibold text-slate-800 text-sm\">Report</p><p class=\"text-xs text-slate-500 leading-snug\">Pin location, add a photo and condition</p></div><div class=\"flex flex-col items-center gap-2\"><div class=\"w-12 h-12 rounded-full bg-green-100 flex items-center justify-center text-xl\">🏡</div><p class=\"font-semibold text-slate-800 text-sm\">Reunite</p><p class=\"text-xs text-slate-500 leading-snug\">Farmer gets an alert and recovers the flock</p></div></div></div><div class=\"mt-10 grid grid-cols-3 gap-3 max-w-sm mx-auto text-center\"><div class=\"bg-white rounded-xl p-3 shadow-sm border border-slate-100\"><div class=\"text-xl font-bold text-green-600\">33M</div><div class=\"text-xs text-slate-500 mt-0.5\">Sheep in UK</div></div><div class=\"bg-white rounded-xl p-3 shadow-sm border border-slate-100\"><div class=\"text-xl font-bold text-green-600\">£80M</div><div class=\"text-xs text-slate-500 mt-0.5\">Annual losses</div></div><div class=\"bg-white rounded-xl p-3 shadow-sm border border-slate-100\"><div class=\"text-xl font-bold text-green-600\">Free</div><div class=\"text-xs text-slate-500 mt-0.5\">30-day trial</div></div></div></div></div><!--$--><!--/$--><script src=\"/_next/static/chunks/0ydoxs82n812q.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[40654,[\\\"/_next/static/chunks/0xefrh70ug086.js\\\",\\\"/_next/static/chunks/0cnc2d8wznqfj.js\\\",\\\"/_next/static/chunks/0dbhjjzl8qfwv.js\\\"],\\\"TranslationProvider\\\"]\\n3:I[18586,[\\\"/_next/static/chunks/0xefrh70ug086.js\\\",\\\"/_next/static/chunks/0cnc2d8wznqfj.js\\\",\\\"/_next/static/chunks/0dbhjjzl8qfwv.js\\\"],\\\"default\\\"]\\n4:I[33533,[\\\"/_next/static/chunks/0xefrh70ug086.js\\\",\\\"/_next/static/chunks/0cnc2d8wznqfj.js\\\",\\\"/_next/static/chunks/0dbhjjzl8qfwv.js\\\"],\\\"default\\\"]\\n5:I[39756,[\\\"/_ne